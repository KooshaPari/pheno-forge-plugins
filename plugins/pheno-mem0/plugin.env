# pheno-mem0 plugin env
# Per ADR-027, Tier 2 (on-demand).

PHENO_PLUGIN_NAME="pheno-mem0"
PHENO_PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PHENO_BINARY_NAME="mem0"
PHENO_BINARY_PATH="${PHENO_BINARY_PATH:-${PHENO_PLUGIN_DIR}/bin/mem0}"
PHENO_BINARY_ARGS="${PHENO_BINARY_ARGS:-server --port 8000}"

PHENO_STATE_DIR="${PHENO_STATE_DIR:-/var/lib/pheno-forge/mem0}"
PHENO_HEALTH_URL="${PHENO_HEALTH_URL:-http://127.0.0.1:8000/health}"
PHENO_HEALTH_TIMEOUT="${PHENO_HEALTH_TIMEOUT:-5}"
PHENO_SD_UNIT="${PHENO_SD_UNIT:-pheno-mem0.service}"

MEM0_VECTOR_STORE="${MEM0_VECTOR_STORE:-qdrant}"
MEM0_LLM_PROVIDER="${MEM0_LLM_PROVIDER:-openai}"
