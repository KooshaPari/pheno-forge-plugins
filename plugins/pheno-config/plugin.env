# pheno-config plugin env
# Per ADR-027, Tier 2 (on-demand).

PHENO_PLUGIN_NAME="pheno-config"
PHENO_PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PHENO_BINARY_NAME="configra"
PHENO_BINARY_PATH="${PHENO_BINARY_PATH:-${PHENO_PLUGIN_DIR}/bin/configra}"
PHENO_BINARY_ARGS="${PHENO_BINARY_ARGS:-daemon --port 9100}"

PHENO_STATE_DIR="${PHENO_STATE_DIR:-/var/lib/pheno-forge/configra}"
PHENO_HEALTH_URL="${PHENO_HEALTH_URL:-http://127.0.0.1:9100/health}"
PHENO_HEALTH_TIMEOUT="${PHENO_HEALTH_TIMEOUT:-5}"
PHENO_SD_UNIT="${PHENO_SD_UNIT:-pheno-config.service}"

CONFIGRA_CONFIG_PATH="${CONFIGRA_CONFIG_PATH:-/etc/pheno-forge/config.toml}"
