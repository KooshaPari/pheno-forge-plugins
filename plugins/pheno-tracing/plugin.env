# pheno-tracing plugin env
# Per ADR-027, Tier 2 (on-demand).

PHENO_PLUGIN_NAME="pheno-tracing"
PHENO_PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PHENO_BINARY_NAME="otelcol-contrib"
PHENO_BINARY_PATH="${PHENO_BINARY_PATH:-${PHENO_PLUGIN_DIR}/bin/otelcol-contrib}"
PHENO_BINARY_ARGS="${PHENO_BINARY_ARGS:---config /etc/pheno-forge/otelcol-contrib.yaml}"

PHENO_STATE_DIR="${PHENO_STATE_DIR:-/var/lib/pheno-forge/tracing}"
PHENO_HEALTH_URL="${PHENO_HEALTH_URL:-http://127.0.0.1:13133/health}"
PHENO_HEALTH_TIMEOUT="${PHENO_HEALTH_TIMEOUT:-5}"
PHENO_SD_UNIT="${PHENO_SD_UNIT:-pheno-tracing.service}"
