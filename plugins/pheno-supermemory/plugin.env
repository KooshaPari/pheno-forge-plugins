# pheno-supermemory plugin env (sourced by scripts/{spawn,teardown,healthcheck}.sh)
# Per ADR-027 (Git LFS 3-tier policy), the binary is Tier 2 (on-demand).
# fetch-sidecars.sh downloads it from upstream releases at install time.

PHENO_PLUGIN_NAME="pheno-supermemory"
PHENO_PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PHENO_BINARY_NAME="supermemory"
PHENO_BINARY_PATH="${PHENO_BINARY_PATH:-${PHENO_PLUGIN_DIR}/bin/supermemory}"
PHENO_BINARY_ARGS="${PHENO_BINARY_ARGS:---port 3030 --store /var/lib/pheno-forge/supermemory}"

PHENO_STATE_DIR="${PHENO_STATE_DIR:-/var/lib/pheno-forge/supermemory}"
PHENO_HEALTH_URL="${PHENO_HEALTH_URL:-http://127.0.0.1:3030/health}"
PHENO_HEALTH_TIMEOUT="${PHENO_HEALTH_TIMEOUT:-5}"
PHENO_SD_UNIT="${PHENO_SD_UNIT:-pheno-supermemory.service}"
