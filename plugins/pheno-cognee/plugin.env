# pheno-cognee plugin env
# cognee-mcp is stdio-based; no HTTP endpoint. Per ADR-027, Tier 2 (on-demand).

PHENO_PLUGIN_NAME="pheno-cognee"
PHENO_PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PHENO_BINARY_NAME="cognee-mcp"
PHENO_BINARY_PATH="${PHENO_BINARY_PATH:-${PHENO_PLUGIN_DIR}/bin/cognee-mcp}"
PHENO_BINARY_ARGS="${PHENO_BINARY_ARGS:---transport stdio}"

PHENO_STATE_DIR="${PHENO_STATE_DIR:-/var/lib/pheno-forge/cognee}"
PHENO_HEALTH_CMD="${PHENO_HEALTH_CMD:-test -S /var/run/pheno-forge/cognee.sock}"
PHENO_HEALTH_TIMEOUT="${PHENO_HEALTH_TIMEOUT:-5}"
PHENO_SD_UNIT="${PHENO_SD_UNIT:-pheno-cognee.service}"

COGNEE_DATASETS="${COGNEE_DATASETS:-phenotype-code,phenotype-docs,phenotype-adrs}"
