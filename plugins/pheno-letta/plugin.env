# pheno-letta plugin env
# Per ADR-027, the letta binary is Tier 2 (on-demand).

PHENO_PLUGIN_NAME="pheno-letta"
PHENO_PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PHENO_BINARY_NAME="letta"
PHENO_BINARY_PATH="${PHENO_BINARY_PATH:-${PHENO_PLUGIN_DIR}/bin/letta}"
PHENO_BINARY_ARGS="${PHENO_BINARY_ARGS:-server --port 8283}"

PHENO_STATE_DIR="${PHENO_STATE_DIR:-/var/lib/pheno-forge/letta}"
PHENO_HEALTH_URL="${PHENO_HEALTH_URL:-http://127.0.0.1:8283/v1/health}"
PHENO_HEALTH_TIMEOUT="${PHENO_HEALTH_TIMEOUT:-5}"
PHENO_SD_UNIT="${PHENO_SD_UNIT:-pheno-letta.service}"

LETTA_AGENT_ID="${LETTA_AGENT_ID:-default-agent}"
